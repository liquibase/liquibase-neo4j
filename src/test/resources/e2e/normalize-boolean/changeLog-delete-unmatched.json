          {
            "cypher": "CREATE (:Movie {watched: 'YES'}) CREATE (:Movie {watched: 'no'}) CREATE (:Movie {watched: 'maybe'}) CREATE (:Movie {watched: true}) CREATE (:Person)-[:SEEN {watched: 'YES'}]->(:Person)"
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "normalize-watched",
        "author": "superstar",
        "changes": [
          {
            "normalizeBoolean": {
              "property": "watched",
              "trueValues": "YES,y",
              "falseValues": "no,n",
              "deleteUnmatched": true
            }
          }
        ]
      }
    }
  ]
}
